{
  "name": "ai-studio-applet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev apps/dashboard -p 3010",
    "dev:all": "npm run dev",
    "build": "next build apps/dashboard",
    "start": "next start apps/dashboard -p 3010",
    "publish:iis": "powershell -ExecutionPolicy Bypass -File scripts/Publish-DleDashboardIis.ps1",
    "start:iis": "powershell -ExecutionPolicy Bypass -File deployment/iis/Start-DleDashboard.ps1",
    "lint": "eslint apps/dashboard --ignore-pattern **/.next --ignore-pattern **/node_modules",
    "clean": "node -e \"require('fs').rmSync('apps/dashboard/.next',{recursive:true,force:true}); console.log('Cleaned apps/dashboard/.next');\""
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@hookform/resolvers": "^5.2.1",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "mssql": "^12.5.5",
    "mysql2": "^3.22.5",
    "next": "^15.4.9",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/mssql": "^12.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "9.39.1",
    "eslint-config-next": "16.0.8",
    "firebase-tools": "^15.0.0",
    "tailwindcss": "4.1.11",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3"
  }
}
